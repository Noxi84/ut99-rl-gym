{
  "_doc": "Canonical UT99 Botpack.Pickup-subclass registry. Single source of truth voor respawn-timings, categorie en T3D class-aliasing. Wordt geladen door (a) ExtractMapBoundsMain bij T3D parse en (b) runtime code dat respawn_seconds nodig heeft voor feature-normalisatie en reward-cap. Geen defaults / fallbacks: een T3D-class die hier ontbreekt wordt door de extract stil overgeslagen, een canonical name die runtime gevraagd wordt maar hier ontbreekt is een hard error.",
  "semantic_groups": {
    "_doc": "Slot-grouping voor high-value pickup features in rl_pawn. Elke key is een semantic type (gebruikt in feature-namen als pickup_<semantic>_<slot>_...). De waarde is een lijst van canonical class-namen die deze slot mogen bezetten — eerste die in de map voorkomt wint. Volgorde van listing = prioriteit (bv. Armor2 > Armor want Armor2 = Botpack BigArmor en is de stock CTF-armor).",
    "shieldbelt":  ["ShieldBelt", "UT_ShieldBelt"],
    "armor":       ["Armor2", "Armor"],
    "thighpads":   ["ThighPads"],
    "amp":         ["UDamage"],
    "megahealth":  ["SuperHealth"]
  },
  "extended_groups": {
    "_doc": "Pad-A pickup-awareness uitbreiding (mei 2026). Top-K nearest dynamische slot-vulling per categorie, naast de bestaande vaste semantic_groups. Slot 0..K-1 = sorteer-volgorde herberekend per frame. 'heal' sort = effective_heal_norm priority (vials > medbox als hp>=100, anders medbox > vials), daarna afstand. 'weapon' sort = afstand. Feature-ID format: pickupx_<group>_<slot>_<attr>.",
    "heal": {
      "_doc": "Health pickups unified. HealthPack en MedBox zijn equivalent (20 hp, cap=100). HealthVial = 5 hp, cap=199. SuperHealth zit al in 'megahealth' semantic_group → niet hier dupliceren.",
      "canonicals": ["MedBox", "HealthPack", "HealthVial"],
      "slot_count": 3,
      "sort_mode": "effective_heal_priority",
      "heal_amounts": { "MedBox": 20, "HealthPack": 20, "HealthVial": 5 },
      "heal_caps":    { "MedBox": 100, "HealthPack": 100, "HealthVial": 199 }
    },
    "weapon": {
      "_doc": "Alle wapen-pickups. Bot leert via bot_owns_weapon flag of 't pickup hem een nieuw wapen geeft (high value) of alleen ammo (low value).",
      "canonicals": [
        "ImpactHammer", "Enforcer", "UT_BioRifle", "ShockRifle", "Ripper",
        "Minigun2", "MinigunCannon", "PulseGun", "SniperRifle",
        "UT_FlakCannon", "UT_Eightball", "Translocator", "WarheadLauncher"
      ],
      "slot_count": 3,
      "sort_mode": "distance"
    }
  },
  "ammo_per_class": {
    "_doc": "Per stock UT99-ammo-canonical één slot (top-1 nearest). 8 stock classes. Variants (FlakBox/MiniAmmo/RifleShells/ShellBox) excluded — variants triggeren wel pickup-events maar delen geen dedicated feature-slot om aantal features te beperken. 'feeds_weapons' = canonical weapon classes die deze ammo verbruiken (gebruikt voor is_for_curr_weapon flag). BulletBox feeds Minigun + SniperRifle (stock UT99: beide schieten bullets).",
    "classes": {
      "EClip":       { "feeds_weapons": ["Enforcer"] },
      "BulletBox":   { "feeds_weapons": ["Minigun2", "MinigunCannon", "SniperRifle"] },
      "BioAmmo":     { "feeds_weapons": ["UT_BioRifle"] },
      "ShockCore":   { "feeds_weapons": ["ShockRifle"] },
      "BladeHopper": { "feeds_weapons": ["Ripper"] },
      "PAmmo":       { "feeds_weapons": ["PulseGun"] },
      "FlakAmmo":    { "feeds_weapons": ["UT_FlakCannon"] },
      "RocketPack":  { "feeds_weapons": ["UT_Eightball"] }
    }
  },
